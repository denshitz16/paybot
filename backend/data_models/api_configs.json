{
    "title": "api_configs",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "description": "Primary key, auto-increment"
        },
        "user_id": {
            "type": "string",
            "description": "User ID of the admin who configured"
        },
        "config_key": {
            "type": "string",
            "description": "Configuration key name, e.g. XENDIT_SECRET_KEY, TELEGRAM_BOT_TOKEN"
        },
        "config_value": {
            "type": "string",
            "description": "Encrypted configuration value"
        },
        "service_name": {
            "type": "string",
            "description": "Service name, e.g. xendit, telegram"
        },
        "is_active": {
            "type": "boolean",
            "description": "Whether this config is active",
            "default": true
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
        },
        "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
        }
    },
    "required": [
        "id",
        "user_id",
        "config_key",
        "config_value",
        "service_name"
    ]
}