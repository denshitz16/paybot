# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./paybot.db
# Public TCP proxy URL for Railway PostgreSQL.
# Railway exposes a public TCP endpoint (e.g. gondola.proxy.rlwy.net:45681) that
# can be used to connect from outside the Railway private network (local dev, CI).
# When DATABASE_URL contains a .railway.internal hostname and the app is NOT running
# inside Railway, it will automatically fall back to this value.
# Format: postgresql://<user>:<password>@<tcp-proxy-host>:<port>/<database>
# Find it in Railway dashboard → your PostgreSQL service → Connect → Public Network.
DATABASE_PUBLIC_URL=postgresql://postgres:PASSWORD@gondola.proxy.rlwy.net:45681/railway

# Payment Service Configuration
# Required in production
XENDIT_SECRET_KEY=your_xendit_secret_key

# PayMongo API - for Alipay, WeChat Pay, GCash, Maya, card payments
# Get keys from: https://dashboard.paymongo.com → Developers → API Keys
PAYMONGO_SECRET_KEY=sk_live_your_paymongo_secret_key
PAYMONGO_PUBLIC_KEY=pk_live_your_paymongo_public_key
# Webhook signing secret — found in PayMongo Dashboard → Developers → Webhooks
# Required for signature verification; create a webhook pointing to:
#   https://paybot-backend-production-84b2.up.railway.app/api/v1/paymongo/webhook
# Events to enable: source.chargeable, checkout_session.payment.paid,
#                   checkout_session.payment.failed, payment.paid, payment.failed
PAYMONGO_WEBHOOK_SECRET=whsk_your_paymongo_webhook_signing_secret
# "test" (sandbox) or "live" (production) — controls which signature key is validated
PAYMONGO_MODE=live

# ---------------------------------------------------------------------------
# PhotonPay API — Alipay and WeChat Pay collection  [REQUIRED for Alipay/WeChat Pay]
# ---------------------------------------------------------------------------
# Setup steps:
#   1. Log in to https://merchant.photonpay.com
#   2. Go to Settings → Developer
#      • Copy "App ID"     → PHOTONPAY_APP_ID
#      • Copy "App Secret" → PHOTONPAY_APP_SECRET
#      • Upload your RSA PUBLIC key (generated from your private key below)
#      • Download PhotonPay's RSA PUBLIC key → PHOTONPAY_RSA_PUBLIC_KEY
#   3. Go to Collection → Site Management
#      • Copy the Site ID  → PHOTONPAY_SITE_ID
#
# Authentication: the server uses standard OAuth2 Basic auth
#   Authorization: Basic base64(<PHOTONPAY_APP_ID>:<PHOTONPAY_APP_SECRET>)
# If the token endpoint returns {"path":…,"method":…} the App ID or App Secret
# is incorrect, OR PHOTONPAY_MODE does not match the credentials' environment —
# copy them again carefully from the merchant portal and verify PHOTONPAY_MODE.
# ---------------------------------------------------------------------------

# REQUIRED — App ID from PhotonPay merchant portal → Settings → Developer
PHOTONPAY_APP_ID=your_photonpay_app_id

# REQUIRED — App Secret from PhotonPay merchant portal → Settings → Developer
PHOTONPAY_APP_SECRET=your_photonpay_app_secret

# REQUIRED — Site ID from PhotonPay merchant portal → Collection → Site Management
PHOTONPAY_SITE_ID=your_photonpay_site_id

# REQUIRED — Your merchant RSA PRIVATE key (PKCS#8 PEM, never leave your server).
# Generate a key pair with:
#   openssl genrsa -out merchant_private.pem 2048
#   openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt \
#           -in merchant_private.pem -out merchant_private_pkcs8.pem
#   openssl rsa -in merchant_private.pem -pubout -out merchant_public.pem
# Upload merchant_public.pem to PhotonPay portal (Settings → Developer).
# Paste the content of merchant_private_pkcs8.pem below (replace newlines with \n).
PHOTONPAY_RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_MERCHANT_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----

# REQUIRED — PhotonPay PLATFORM RSA PUBLIC key (downloaded from portal → Settings → Developer).
# Used to verify the X-PD-SIGN signature on incoming webhook notifications.
# Supports PKCS#8 ("BEGIN PUBLIC KEY") and PKCS#1 ("BEGIN RSA PUBLIC KEY") PEM formats.
# Paste with literal \n or as a multiline env var.
PHOTONPAY_RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PHOTONPAY_PLATFORM_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----

# payMethod strings — must match the values shown in your PhotonPay merchant account
PHOTONPAY_ALIPAY_METHOD=Alipay
PHOTONPAY_WECHAT_METHOD=WeChat

# Require a valid X-PD-SIGN signature on all incoming webhook requests.
# true (default, recommended for production) — reject unsigned/tampered notifications.
# false — skip signature check (use only during initial integration testing).
PHOTONPAY_WEBHOOK_VERIFY_REQUIRED=true

# Environment mode: "production" (default) or "sandbox"
#   production → https://x-api.photonpay.com          (token: /oauth2/token/accessToken)
#   sandbox    → https://x-api1.uat.photontech.cc     (token: /oauth2/token/accessToken)
# IMPORTANT: this must match the environment your App ID / App Secret belong to.
# Using sandbox credentials against the production URL (or vice versa) causes
# PhotonPay to return {"path":…,"method":…} — an invalid-credentials response.
PHOTONPAY_MODE=production

# Optional: override the API base URL completely (leave blank to derive from PHOTONPAY_MODE)
PHOTONPAY_BASE_URL=

# Optional: override the cashier (hosted checkout) base URL (leave blank to derive from PHOTONPAY_MODE)
PHOTONPAY_CASHIER_URL=

# Telegram Bot Configuration
# Required in production
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Optional explicit bot username for Telegram Login Widget runtime config (without @)
TELEGRAM_BOT_USERNAME=your_telegram_bot_username

# Application Configuration
ENVIRONMENT=production
DEBUG=false
PORT=8000

# General outbound proxy (optional).  Used by payment services when no service-specific
# proxy URL is set.  Set PROXY_HOST to your proxy server hostname or IP address and
# PROXY_PORT to the port number (default 8080 when PROXY_HOST is set).
# Example: PROXY_HOST=proxy.example.com  PROXY_PORT=3128
PROXY_HOST=
PROXY_PORT=

# Backend URL (for webhooks, Telegram webhook auto-registration, and static QR image URLs)
# The USDT TRC20 QR image is served at {PYTHON_BACKEND_URL}/images/usdt_trc20_qr.png
PYTHON_BACKEND_URL=https://paybot-backend-production-84b2.up.railway.app

# CORS Configuration
ALLOWED_ORIGINS=https://paybot-backend-production-84b2.up.railway.app,http://localhost:3000

# JWT Authentication (REQUIRED for admin dashboard login)
# Generate a secure random key, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secure_random_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Cloudflare Turnstile (optional CAPTCHA protection for the admin login page)
# 1. Go to https://dash.cloudflare.com → Turnstile → Add site
# 2. Copy the "Secret Key" here and the "Site Key" to VITE_TURNSTILE_SITE_KEY in the frontend .env
# When set, every Telegram widget login must pass Turnstile server-side verification.
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAAAACsnP7dYcmju2hsCROEuJAY27h0

# Admin Login Configuration (REQUIRED for dashboard access)
# Comma-separated list of Telegram user IDs or @usernames allowed to log in as admin.
# Numeric IDs (e.g. 123456789) or Telegram usernames prefixed with @ (e.g. @traxionpay).
TELEGRAM_ADMIN_IDS=@traxionpay,8595884149
