option_settings:
  aws:elasticbeanstalk:application:environment:
    PYTHONUNBUFFERED: "1"
    ENVIRONMENT: "production"
    LOG_LEVEL: "info"
    
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.micro
    
  aws:ec2:instances:
    InstanceTypes: t3.micro
    
  aws:elasticbeanstalk:command:
    IgnoreHealthCheck: "false"